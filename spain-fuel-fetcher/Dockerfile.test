# Build context = repo root (workspace). See deploy.yaml / makefile.
FROM python:3.13-slim AS builder
COPY --from=ghcr.io/astral-sh/uv:0.6 /uv /uvx /bin/
WORKDIR /app
COPY pyproject.toml uv.lock ./
COPY spain-fuel-fetcher/ ./spain-fuel-fetcher/
COPY fuel-ingestor/pyproject.toml ./fuel-ingestor/
COPY fuel-dashboard/pyproject.toml ./fuel-dashboard/
RUN uv sync --frozen --no-install-project --no-editable --package spain-fuel-fetcher

FROM python:3.13-slim
# curl required: test_fetch.py asserts the curl binary is available.
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /app/.venv /app/.venv
COPY ./spain-fuel-fetcher/src/ ./src/
COPY ./spain-fuel-fetcher/tests/ ./tests/
ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH=/app/src
ENTRYPOINT ["pytest", "--durations=5", "-vv", "/app/tests/"]
